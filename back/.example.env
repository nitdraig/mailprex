# Mailprex deployment modes: internal | public | selfhost
MAILPREX_MODE=public

# Self-host: allow new user registration (default true). Set false to lock down.
# MAILPREX_ALLOW_SIGNUP=true

# Self-host/internal: skip email verification unless explicitly enabled
# MAILPREX_REQUIRE_EMAIL_VERIFY=false

# Internal mode admin seed (registration disabled; login with this account)
# MAILPREX_INTERNAL_ADMIN_EMAIL=admin@example.com
# MAILPREX_INTERNAL_ADMIN_PASSWORD=change-me

PASS=
PORT=5000
EMAILSEND=
MONGODB_URI=
JWT_SECRET=
NODE_ENV=development

# Frontend URL used in verification emails and billing redirects
FRONTEND_URL=http://localhost:3000

# Custom SMTP (self-host / Pro). When set, overrides Gmail defaults.
# MAILPREX_SMTP_HOST=smtp.example.com
# MAILPREX_SMTP_PORT=587
# MAILPREX_SMTP_SECURE=false
# MAILPREX_SMTP_USER=user
# MAILPREX_SMTP_PASS=secret

# Comma-separated origins allowed for /auth (merged with defaults below)
# CORS_ORIGINS=http://localhost:3000,https://mailprex.excelso.xyz,https://www.mailprex.excelso.xyz

# Cloudflare Turnstile (optional — when set, CAPTCHA is required on register/login/email send)
TURNSTILE_SECRET_KEY=

# Google OAuth (Sign in with Google — same Client ID as frontend)
# GOOGLE_CLIENT_ID=

# Max successful sends per recipient email per hour (default: 10)
# RECIPIENT_RATE_LIMIT_PER_HOUR=10

# Gumroad (public mode Pro/Business billing)
# GUMROAD_SELLER_ID=
# GUMROAD_PRODUCT_ID_PRO=
# GUMROAD_URL_PRO=https://yourname.gumroad.com/l/pro
# GUMROAD_PRODUCT_ID_BUSINESS=
# GUMROAD_URL_BUSINESS=https://yourname.gumroad.com/l/business
# GUMROAD_LIBRARY_URL=https://gumroad.com/library
