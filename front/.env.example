# Production (recommended — same-origin proxy for cookies + Google Sign-In)
# NEXT_PUBLIC_API_URL=/api
# API_URL=https://api.mailprex.excelso.xyz

# Production (direct cross-subdomain API)
# NEXT_PUBLIC_API_URL=https://api.mailprex.excelso.xyz

# Local dev (Next.js rewrite to backend — required for httpOnly cookies)
NEXT_PUBLIC_API_URL=/api

# Optional Cloudflare Turnstile (must match TURNSTILE_SECRET_KEY on the API)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Google OAuth (Sign in with Google — Web client ID from Google Cloud Console)
# Authorized JavaScript origins: http://localhost:3000, https://mailprex.excelso.xyz
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

NEXT_PUBLIC_GOOGLEANALYTIC=
NEXT_PUBLIC_EMAIL_DESTINY=
NEXT_PUBLIC_API_URL_SEND=
NEXT_PUBLIC_MAILPREX_FORM_TOKEN=
